# Supabase Configuration
# Get these from https://supabase.com after creating a project
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe Configuration (for payments)
# Get these from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
# Create products in Stripe Dashboard and copy their Price IDs
VITE_STRIPE_PRO_YEARLY_PRICE_ID=price_your-yearly-id
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_your-monthly-id
VITE_STRIPE_LIFE_PRICE_ID=price_your-life-id

# Analytics Configuration
# Google Analytics 4 Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics Domain (if using Plausible)
VITE_PLAUSIBLE_DOMAIN=
